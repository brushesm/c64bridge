{
  "type": "object",
  "description": "System operations available via the c64_system tool.",
  "oneOf": [
    {
      "type": "object",
      "description": "Pause the machine using DMA halt until resumed.",
      "properties": {
        "op": {
          "const": "pause"
        }
      },
      "additionalProperties": false,
      "required": [
        "op"
      ]
    },
    {
      "type": "object",
      "description": "Resume CPU execution after a DMA pause.",
      "properties": {
        "op": {
          "const": "resume"
        }
      },
      "additionalProperties": false,
      "required": [
        "op"
      ]
    },
    {
      "type": "object",
      "description": "Issue a soft reset without cutting power.",
      "properties": {
        "op": {
          "const": "reset"
        }
      },
      "additionalProperties": false,
      "required": [
        "op"
      ]
    },
    {
      "type": "object",
      "description": "Trigger a firmware reboot to recover from faults.",
      "properties": {
        "op": {
          "const": "reboot"
        }
      },
      "additionalProperties": false,
      "required": [
        "op"
      ]
    },
    {
      "type": "object",
      "description": "Request a controlled shutdown via the Ultimate firmware.",
      "properties": {
        "op": {
          "const": "poweroff"
        }
      },
      "additionalProperties": false,
      "required": [
        "op"
      ]
    },
    {
      "type": "object",
      "description": "Toggle the Ultimate menu button for navigation.",
      "properties": {
        "op": {
          "const": "menu"
        }
      },
      "additionalProperties": false,
      "required": [
        "op"
      ]
    },
    {
      "type": "object",
      "description": "Start a named background task that runs on an interval.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique task name",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "description": "Operation name (e.g., read, read_screen)",
          "minLength": 1
        },
        "arguments": {
          "type": [
            "object",
            "null"
          ],
          "description": "Operation-specific arguments",
          "properties": {},
          "additionalProperties": true,
          "default": {}
        },
        "intervalMs": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Interval milliseconds",
          "minimum": 1,
          "default": 1000
        },
        "maxIterations": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of iterations (omit for indefinite)",
          "minimum": 1
        },
        "op": {
          "const": "start_task"
        }
      },
      "required": [
        "name",
        "operation",
        "op"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "description": "Stop a specific background task and clear its timer.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Task name",
          "minLength": 1
        },
        "op": {
          "const": "stop_task"
        }
      },
      "required": [
        "name",
        "op"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "description": "Stop every running background task and persist state.",
      "properties": {
        "op": {
          "const": "stop_all_tasks"
        }
      },
      "additionalProperties": false,
      "required": [
        "op"
      ]
    },
    {
      "type": "object",
      "description": "List known background tasks with status metadata.",
      "properties": {
        "op": {
          "const": "list_tasks"
        }
      },
      "additionalProperties": false,
      "required": [
        "op"
      ]
    }
  ],
  "discriminator": {
    "propertyName": "op"
  }
}
